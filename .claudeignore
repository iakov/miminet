# .claudeignore

# Исключить файлы из контекста Claude Code для ускорения анализа

# ============================================================================
# Python
# ============================================================================
*.pyc
*.pyo
*.pyd
__pycache__/
*.so
*.egg
*.egg-info/
dist/
build/
*.whl

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# ============================================================================
# Dependencies
# ============================================================================
node_modules/
bower_components/
vendor/

# ============================================================================
# Generated files
# ============================================================================
*.log
*.pcap
*.cap
*.out
*.pid

# Database migrations (кроме последней)
# Раскомментируйте, если миграций много:
# migrations/versions/*.py

# ============================================================================
# Test artifacts
# ============================================================================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/
pytest_debug.log

# ============================================================================
# Docker volumes и кеш
# ============================================================================
postgres_data/
redis_data/
rabbitmq_data/
.docker/

# ============================================================================
# IDE и редакторы
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================================================
# Static assets (большие библиотеки)
# ============================================================================
front/src/static/lib/
front/src/static/vendor/
front/src/static/images/screenshots/
front/src/static/fonts/

# Если есть большие JS библиотеки:
# front/src/static/js/lib/

# ============================================================================
# Compiled assets
# ============================================================================
*.min.js
*.min.css
*.map

# ============================================================================
# Temporary files
# ============================================================================
*.tmp
*.bak
*.backup
.temp/
tmp/

# ============================================================================
# OS files
# ============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ============================================================================
# Git
# ============================================================================
.git/
.gitignore
.gitattributes

# ============================================================================
# Documentation (если слишком большие)
# ============================================================================
# docs/build/
# docs/_build/
# Раскомментируйте, если документация очень объемная

# ============================================================================
# Secrets и конфигурация
# ============================================================================
*.pem
*.key
*.crt
*.p12
.env.local
.env.*.local
secrets/
vk_auth.json
miminet_secret.conf

# ============================================================================
# Logs
# ============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================================================
# Ansible
# ============================================================================
ansible/*.retry

# ============================================================================
# Vagrant
# ============================================================================
.vagrant/

# ============================================================================
# CI/CD artifacts
# ============================================================================
.github/workflows/*.log

# ============================================================================
# Large binary files
# ============================================================================
*.zip
*.tar
*.tar.gz
*.rar
*.7z
*.iso

# ============================================================================
# Media files (если есть загруженные пользователями)
# ============================================================================
# uploads/
# media/

# ============================================================================
# Specific to Miminet
# ============================================================================

# Большие test outputs
back/tests/outputs/*.pcap
front/tests/screenshots/*.png

# Compiled Mininet
*.mn

# Network dumps
*.json.bak
